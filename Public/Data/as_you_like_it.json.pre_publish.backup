    },
    "66": {
      "play": "But, mistress, know yourself. Down on your knees",
      "notes": []
    },
    "67": {
      "play": "And thank heaven, fasting, for a good man’s love,",
      "notes": []
    },
    "68": {
      "play": "For I must tell you friendly in your ear,",
      "notes": []
    },
    "69": {
      "play": "Sell when you can; you are not for all markets.",
      "notes": []
