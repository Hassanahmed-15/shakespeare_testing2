    "52": {
      "play": "wishes for.",
      "notes": []
    },
    "53": {
      "play": "ROSALIND, as Ganymede  Why, then, tomorrow I cannot",
      "notes": []
    },
    "54": {
      "play": "serve your turn for Rosalind?",
      "notes": []
