      "notes": []
    },
    "62": {
      "play": "Even by the squand’ring glances of the fool.",
      "notes": [
        "squandering] See the citations in proof that to ‘squander’ means to scatter in Mer. of Ven. I, iii, 22: ‘Other ventures hee hath squandred abroad.’",
        "squandring] See the citations in proof that to ‘squander’ means to scatter in Mer. of Ven. I, iii, 22: ‘Other ventures hee hath squandred abroad.’"
      ]
    },
    "63": {
      "play": "Invest me in my motley. Give me leave",
