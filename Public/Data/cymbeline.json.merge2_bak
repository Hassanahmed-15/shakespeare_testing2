      "play": "She draws Pisanio’s sword from its",
      "notes": []
    },
    "75": {
      "play": "scabbard and hands it to him.",
      "notes": []
    },
    "76": {
      "play": "Take it, and hit",
      "notes": []
    },
    "77": {
      "play": "The innocent mansion of my love, my heart.",
      "notes": []
    },
    "78": {
      "play": "Fear not; ’tis empty of all things but grief.",
