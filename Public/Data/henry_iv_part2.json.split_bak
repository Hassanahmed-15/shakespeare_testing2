    "33": {
      "play": "MOWBRAY: I think it is my Lord of Westmoreland.",
      "notes": []
    },
    "34": {
      "play": "WESTMORELAND: Health and fair greeting from our general,",
      "notes": [
        "Health] N.E.D. (Health sb. 5): Well-being, welfare, safety; deliverance.—[Cf. iv.iv.93, iv.v.247, v.iii.49.]"
      ]
    },
    "35": {
      "play": "The Prince Lord John and Duke of Lancaster.",
      "notes": []
